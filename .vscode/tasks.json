// ALL COMMANDS
{
  "version": "2.0.0",
  "tasks": [
    {
        "label": "Build Code (main.cpp)",
        "type": "shell",
        "command": "pio",
        "args": [
            "run"
        ],
        "group": "build"
    },
    {
        "label": "Test Testfiles (test_main.cpp)",
        "type": "shell",
        "command": "pio",
        "args": [
            "test",
            "-e",
            "native"
        ],
        "group": "test"
    },
    {
        "label": "Upload to Microcontroller",
        "type": "shell",
        "command": "pio",
        "args": [
            "run",
            "-e",
            "teensy41",
            "-t",
            "upload"
        ]
    },
    {
        "label": "Open Serial Monitor",
        "type": "shell",
        "command": "pio",
        "args": [
            "device",
            "monitor"
        ]
    },
    {
        "label": "Build Doxygen (Only works if installed on computer)",
        "type": "shell",
        "command": "doxygen",
        "args": [
            "tools/Doxygen"
        ]
    },
    {
        "label": "Git Pull: Get Code from Github",
        "type": "shell",
        "dependsOn": [
            "_git_pull_merge"
        ],
        "dependsOrder": "sequence",
        "problemMatcher": []
    },
    {
        "label": "Git Push: Save and Publish Your Code",
        "dependsOn": [
            "_git_stage_all",
            "_git_commit_if_needed",
            "_git_pull_merge",
            "_git_push"
        ],
        "dependsOrder": "sequence",
        "problemMatcher": [],
        "group": {
            "kind": "test",
            "isDefault": true
        }
    },
    {
        "label": "_git_stage_all",
        "type": "shell",
        "command": "git",
        "args": [
            "add",
            "-A"
        ],
        "hide": true,
        "problemMatcher": []
    },
    {
        "label": "_git_commit_if_needed",
        "type": "shell",
        "command": "git",
        "args": [
            "commit",
            "-m",
            "\"${input:commitMessage}\""
        ],
        "hide": true,
        "problemMatcher": []
    },
    {
        "label": "_git_pull_merge",
        "type": "shell",
        "command": "git",
        "args": [
            "pull",
            "--no-rebase"
        ],
        "hide": true,
        "problemMatcher": []
    },
    {
        "label": "_git_push",
        "type": "shell",
        "command": "git",
        "args": [
            "push"
        ],
        "hide": true,
        "problemMatcher": []
    }
],
  // Input Commit Message
  "inputs": [
    {
        "id": "commitMessage",
        "type": "promptString",
        "description": "What changed (click enter when done)?",
        "default": "list changes"
    }
  ]
}